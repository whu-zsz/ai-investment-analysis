# Server Configuration
SERVER_PORT=8080

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=stock_analysis

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRE_HOURS=24

# LLM Configuration
# 只填 deepseek 或 doubao 二选一，并与下面对应配置保持一致
LLM_PROVIDER=deepseek

# Deepseek API Configuration
# 使用 DeepSeek 时：
# 1) LLM_PROVIDER=deepseek
# 2) DEEPSEEK_API_KEY 填真实可用的 key
# 3) DEEPSEEK_API_URL 一般保持默认
# 4) DEEPSEEK_MODEL 一般使用 deepseek-chat
DEEPSEEK_API_KEY=your_real_deepseek_api_key
DEEPSEEK_API_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Doubao / Ark API Configuration
# 使用豆包 / Ark 时：
# 1) LLM_PROVIDER=doubao
# 2) DOUBAO_API_KEY 填真实可用的 key
# 3) DOUBAO_API_URL 一般保持默认
# 4) DOUBAO_MODEL 必须填写你在火山方舟创建的 endpoint / model id
DOUBAO_API_KEY=your_real_doubao_api_key
DOUBAO_API_URL=https://ark.cn-beijing.volces.com
DOUBAO_MODEL=your_ark_endpoint_or_model_id

# Market Snapshot Configuration
MARKET_ENABLED=true
MARKET_PROVIDER=mock
MARKET_SYMBOLS=000001.SH,399001.SZ,399006.SZ,000300.SH
MARKET_SNAPSHOT_INTERVAL=60
MARKET_TIMEOUT_SECONDS=5
MARKET_EASTMONEY_BASE_URL=https://push2.eastmoney.com/api/qt/ulist.np/get
MARKET_EASTMONEY_USER_AGENT=Mozilla/5.0
MARKET_EASTMONEY_REFERER=https://quote.eastmoney.com/center/gridlist.html

# Upload Configuration
UPLOAD_PATH=./uploads
MAX_UPLOAD_SIZE=10485760
